#!/bin/sh
# Resolve the exact AAPT2 binary downloaded by AGP. Google's Linux artifact is
# x86_64; run it directly on x86_64 CI and through QEMU on arm64 development.
gradle_home="${GRADLE_USER_HOME:-${HOME:?}/.gradle}"
if [ ! -d "$gradle_home/caches" ]; then
    echo "The Gradle cache directory is required to locate the resolved AAPT2 binary." >&2
    exit 127
fi
aapt2_binary=$(find "$gradle_home/caches" -path '*/aapt2-9.2.1-15009934-linux/aapt2' -type f -print -quit)
if [ -z "$aapt2_binary" ]; then
    echo "The resolved AAPT2 9.2.1 binary was not found in the Gradle cache." >&2
    exit 127
fi
case "$(uname -m)" in
    aarch64|arm64)
        if ! command -v qemu-x86_64 >/dev/null 2>&1; then
            echo "FluxLab arm64 builds require qemu-x86_64 for Android SDK AAPT2." >&2
            exit 127
        fi
        exec qemu-x86_64 "$aapt2_binary" "$@"
        ;;
    *) exec "$aapt2_binary" "$@" ;;
esac
